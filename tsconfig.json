{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,

    // Menggunakan kombinasi Node16/NodeNext yang fleksibel
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2022",
    "types": ["node"],

    // Mengizinkan tsc melakukan build tanpa memaksa penulisan ekstensi .js palsu di kode .ts
    "rewriteRelativeImportExtensions": true, 

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["src"]
}